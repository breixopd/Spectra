{
  "id": "dirsearch",
  "name": "Dirsearch",
  "version": "1.0.0",
  "category": "enumeration",
  "description": "Advanced web path brute-forcer with recursive scanning and smart filtering.",
  "metadata": {
    "ai_description": "Dirsearch is a mature command-line web path scanner. It finds hidden directories, files, and endpoints. Supports recursive scanning, multiple extensions, smart filtering of false positives. More thorough than gobuster for complex web apps.",
    "capabilities": [
      "directory_brute",
      "web_crawl"
    ],
    "supported_targets": [
      "url",
      "domain"
    ],
    "risk_level": "low",
    "tags": [
      "web",
      "directories",
      "enumeration",
      "brute-force"
    ],
    "use_cases": [
      "Find hidden directories and files on web servers",
      "Discover admin panels and backup files",
      "Recursive scanning of discovered directories"
    ],
    "limitations": [
      "May trigger WAF or rate limiting",
      "Wordlist dependent"
    ],
    "complements": [
      "gobuster",
      "ffuf",
      "nuclei"
    ],
    "prerequisites": [
      "nmap"
    ]
  },
  "installation": {
    "method": "pipx",
    "commands": [
      "pip3 install dirsearch"
    ],
    "verification_command": "dirsearch --help",
    "verification_regex": "dirsearch"
  },
  "execution": {
    "command": "dirsearch",
    "args_template": "-u {target} --format=json -o {output_file} {extensions} {flags}",
    "timeout": 600,
    "min_timeout": 60,
    "max_timeout": 1800,
    "arg_modifiers": {
      "extensions": {
        "prefix": "-e ",
        "separator": ","
      }
    }
  },
  "parsing": {
    "format": "json",
    "mapping": {
      "url": "url",
      "status": "status",
      "content_length": "content-length"
    }
  },
  "stealth": {
    "rate_limit": 10,
    "delay_ms": 200,
    "extra_args": {
      "--delay": "0.5"
    }
  },
  "ui": {
    "icon": "folder-open",
    "color": "amber"
  },
  "examples": [
    {
      "description": "Default directory scan",
      "args": {
        "target": "http://192.168.1.10"
      }
    },
    {
      "description": "Scan with extensions",
      "args": {
        "target": "http://192.168.1.10",
        "extensions": "php,asp,html"
      }
    },
    {
      "description": "Recursive scan with depth limit",
      "args": {
        "target": "http://192.168.1.10",
        "flags": "--recursion --recursion-depth 3"
      }
    }
  ],
  "signature": "4e2bb2f3ac267ca2d43de2301d4a8f84efd9b59ec0850a6031fab08b3afb66d90a3658bf6c3b5202626db8aa13fa3b0230a02857ba607dedd7fa4437f99c300f",
  "resources": {
    "tier": "medium"
  }
}
