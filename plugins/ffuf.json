{
  "id": "ffuf",
  "name": "Ffuf",
  "version": "1.0.0",
  "category": "enumeration",
  "description": "Fast web fuzzer written in Go",
  "metadata": {
    "ai_description": "Ffuf is the fastest and most versatile web fuzzer available. Use it for directory brute-forcing, parameter discovery, virtual host enumeration, and any HTTP-based fuzzing task. More flexible than gobuster with support for multiple FUZZ positions, filters, and matchers. Excellent for API endpoint discovery and parameter fuzzing.",
    "capabilities": [
      "directory_brute",
      "parameter_fuzzing",
      "vhost_discovery",
      "web_crawl"
    ],
    "supported_targets": [
      "url"
    ],
    "risk_level": "low",
    "tags": [
      "web",
      "fuzzing",
      "directories",
      "parameters",
      "api",
      "fast"
    ],
    "use_cases": [
      "Fast directory and file enumeration",
      "Parameter discovery and fuzzing",
      "Virtual host discovery",
      "API endpoint enumeration",
      "Custom header and cookie fuzzing"
    ],
    "limitations": [
      "Requires careful filter configuration to avoid false positives",
      "High speed may trigger rate limiting",
      "Wordlist-dependent"
    ],
    "complements": [
      "nuclei",
      "nikto",
      "sqlmap"
    ],
    "prerequisites": [
      "nmap"
    ]
  },
  "installation": {
    "method": "apt",
    "commands": [
      "apt-get update",
      "apt-get install -y ffuf seclists"
    ],
    "verification_command": "test -f /usr/share/seclists/Discovery/Web-Content/common.txt && ffuf -V",
    "verification_regex": "ffuf",
    "uninstall_commands": [
      "apt-get remove -y ffuf",
      "apt-get autoremove -y"
    ]
  },
  "execution": {
    "command": "ffuf",
    "args_template": "-u {target} -w /usr/share/seclists/Discovery/Web-Content/common.txt {extensions} -o {output_file} -of json {flags}",
    "timeout": 600,
    "arg_modifiers": {
      "extensions": {
        "prefix": "-e ",
        "separator": ","
      }
    }
  },
  "parsing": {
    "format": "json",
    "mapping": {
      "url": "url",
      "status": "status",
      "length": "length",
      "words": "words"
    }
  },
  "ui": {
    "icon": "crosshair",
    "color": "yellow"
  },
  "examples": [
    {
      "description": "Directory fuzzing",
      "args": {
        "target": "http://192.168.1.10/FUZZ"
      }
    },
    {
      "description": "Parameter fuzzing with filter",
      "args": {
        "target": "http://192.168.1.10/page?id=FUZZ",
        "flags": "-fw 10"
      }
    },
    {
      "description": "Virtual host discovery",
      "args": {
        "target": "http://192.168.1.10",
        "flags": "-H 'Host: FUZZ.example.com' -w /usr/share/seclists/Discovery/DNS/subdomains-top1million-5000.txt"
      }
    }
  ],
  "resources": {
    "tier": "medium"
  }
}
