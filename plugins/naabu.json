{
  "id": "naabu",
  "name": "Naabu",
  "version": "1.0.0",
  "category": "discovery",
  "description": "Fast port scanner written in Go. Designed to scan large networks efficiently.",
  "metadata": {
    "ai_description": "Naabu is an extremely fast port scanner optimized for large-scale network scanning. Use it for initial host discovery when you need speed over detail. It's faster than Nmap for pure port scanning but doesn't do service detection. Ideal for scanning CIDR ranges to find live hosts quickly, then follow up with Nmap for detailed service enumeration.",
    "capabilities": [
      "port_scan",
      "host_discovery"
    ],
    "supported_targets": [
      "ip",
      "ip_range",
      "cidr",
      "host"
    ],
    "risk_level": "low",
    "tags": [
      "fast",
      "ports",
      "network",
      "discovery",
      "masscan-alternative"
    ],
    "use_cases": [
      "Fast initial port scanning of large networks",
      "Host discovery across CIDR ranges",
      "Quick verification of open ports",
      "Complementing Nmap with faster initial scans"
    ],
    "limitations": [
      "No service version detection",
      "No OS fingerprinting",
      "May miss ports with slow responses",
      "Less accurate than Nmap for specific port states"
    ],
    "complements": [
      "nmap",
      "nuclei"
    ],
    "prerequisites": []
  },
  "installation": {
    "method": "go",
    "commands": [
      "apt-get update",
      "apt-get install -y libpcap-dev golang",
      "go install -v github.com/projectdiscovery/naabu/v2/cmd/naabu@latest",
      "ln -sf /root/go/bin/naabu /usr/local/bin/naabu"
    ],
    "verification_command": "naabu -version",
    "verification_regex": "naabu",
    "uninstall_commands": [
      "rm -f /usr/local/bin/naabu",
      "rm -f /root/go/bin/naabu"
    ]
  },
  "execution": {
    "command": "naabu",
    "args_template": "-host {target} {ports} {flags} -json -o {output_file}",
    "timeout": 300,
    "arg_modifiers": {
      "ports": {
        "prefix": "-p",
        "separator": ","
      }
    }
  },
  "parsing": {
    "format": "ndjson",
    "mapping": {
      "host": "host",
      "ip": "ip",
      "port": "port"
    }
  },
  "ui": {
    "icon": "lightning",
    "color": "green"
  },
  "signature": "e87ee6b4314793ab44f1c7bb16303a5445bdeb7a6a79dc7619203f8df1156e9ed8b36c77bf1361ad1951d91ebf7439c49c2885be53470ec422603338ad3a1500"
}
