{
  "id": "httpx",
  "name": "httpx",
  "version": "1.0.0",
  "category": "discovery",
  "description": "Fast HTTP probe tool. Identifies live web servers, technologies, status codes, and titles.",
  "metadata": {
    "ai_description": "httpx is a fast and multi-purpose HTTP toolkit. Use it to probe discovered hosts for live web services, extract page titles, status codes, technologies, and content lengths. Excellent for initial web service discovery before running heavier scanners.",
    "capabilities": [
      "web_fingerprint",
      "host_discovery",
      "service_detection"
    ],
    "supported_targets": [
      "ip",
      "domain",
      "url",
      "cidr"
    ],
    "risk_level": "passive",
    "tags": [
      "web",
      "http",
      "probe",
      "discovery",
      "fast"
    ],
    "use_cases": [
      "Quickly identify live web servers from a list of hosts",
      "Extract page titles and technologies",
      "Identify HTTP vs HTTPS services"
    ],
    "limitations": [
      "HTTP/HTTPS only",
      "Does not do deep scanning"
    ],
    "complements": [
      "nmap",
      "nuclei",
      "whatweb"
    ],
    "prerequisites": []
  },
  "installation": {
    "method": "go",
    "commands": [
      "go install -v github.com/projectdiscovery/httpx/cmd/httpx@latest"
    ],
    "verification_command": "httpx -version",
    "verification_regex": "httpx"
  },
  "execution": {
    "command": "httpx",
    "args_template": "-u {target} -json -o {output_file} -silent -title -tech-detect -status-code {flags}",
    "timeout": 120,
    "min_timeout": 15,
    "max_timeout": 300
  },
  "parsing": {
    "format": "ndjson",
    "mapping": {
      "url": "url",
      "status": "status_code",
      "title": "title",
      "technologies": "tech"
    }
  },
  "ui": {
    "icon": "globe",
    "color": "green"
  },
  "signature": "35e3a2e6c88bb66de004fe4fa6d737299de7b58eba296cc6ef43ab3707665c8ed69d1df4473ceb6bdcbfd655aadbc2f8167a80365de176eb409ed910b1bf110d"
}
