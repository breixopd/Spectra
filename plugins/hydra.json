{
  "id": "hydra",
  "name": "Hydra",
  "version": "1.0.0",
  "category": "exploitation",
  "description": "Fast and flexible online password cracking tool",
  "metadata": {
    "ai_description": "Hydra is the premier online password brute-forcing tool. Use it when you need to test authentication on services like SSH, FTP, HTTP, SMB, RDP, MySQL, and 50+ other protocols. Best used after discovering open services with nmap. Can perform both brute-force attacks and credential spraying (one password against many users).",
    "capabilities": [
      "brute_force",
      "credential_spray"
    ],
    "supported_targets": [
      "ip",
      "host",
      "url"
    ],
    "risk_level": "medium",
    "tags": [
      "passwords",
      "brute-force",
      "authentication",
      "credentials",
      "ssh",
      "ftp",
      "http",
      "smb"
    ],
    "use_cases": [
      "Brute-forcing SSH, FTP, Telnet logins",
      "Testing web form authentication",
      "SMB/Windows credential testing",
      "Database authentication testing (MySQL, PostgreSQL)",
      "Credential spraying across services"
    ],
    "limitations": [
      "Account lockout policies may block attempts",
      "Can be very slow without good wordlists",
      "May trigger security alerts and IP bans",
      "Not effective against MFA"
    ],
    "complements": [
      "nmap",
      "crackmapexec"
    ],
    "prerequisites": [
      "nmap"
    ]
  },
  "installation": {
    "method": "apt",
    "commands": [
      "apt-get update",
      "apt-get install -y hydra"
    ],
    "verification_command": "hydra -h",
    "verification_regex": "Hydra",
    "uninstall_commands": [
      "apt-get remove -y hydra",
      "apt-get autoremove -y"
    ]
  },
  "execution": {
    "command": "hydra",
    "args_template": "-L {userlist} -P {passlist} {target} {service} -o {output_file} {flags}",
    "timeout": 1800,
    "timeout_per_host": 600,
    "min_timeout": 300,
    "max_timeout": 7200,
    "success_exit_codes": [
      0,
      255
    ]
  },
  "parsing": {
    "format": "text",
    "mapping": {},
    "regex_patterns": [
      {
        "pattern": "\\[(\\d+)\\]\\[(\\w+)\\] host: (.+)\\s+login: (.+)\\s+password: (.+)",
        "type": "vuln"
      },
      {
        "pattern": "(\\d+) valid passwords? found",
        "type": "info"
      },
      {
        "pattern": "\\[ERROR\\]\\s+(?P<error>.+)",
        "type": "info"
      }
    ]
  },
  "examples": [
    {
      "description": "Brute-force SSH login",
      "args": {
        "target": "192.168.1.10",
        "service": "ssh",
        "userlist": "users.txt",
        "passlist": "passwords.txt"
      }
    },
    {
      "description": "HTTP POST form brute-force",
      "args": {
        "target": "192.168.1.10",
        "service": "http-post-form",
        "flags": "-l admin -P passwords.txt '/login:user=^USER^&pass=^PASS^:Invalid'"
      }
    },
    {
      "description": "FTP credential spray",
      "args": {
        "target": "192.168.1.10",
        "service": "ftp",
        "userlist": "users.txt",
        "passlist": "passwords.txt",
        "flags": "-t 4"
      }
    }
  ],
  "ui": {
    "icon": "key",
    "color": "orange"
  },
  "resources": {
    "tier": "heavy"
  }
}
