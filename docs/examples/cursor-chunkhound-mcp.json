{
  "mcpServers": {
    "chunkhound": {
      "command": "ssh",
      "args": [
        "-i",
        "/ABSOLUTE/PATH/.ssh/id_ed25519_chunkhound_vps",
        "-o",
        "BatchMode=yes",
        "-o",
        "ConnectTimeout=15",
        "root@YOUR_VPS_HOST",
        "cd /path/to/Spectra && export CHUNKHOUND_CONFIG_FILE=/root/.config/chunkhound/config.json && exec /opt/chunkhound-venv/bin/chunkhound mcp --stdio --db .chunkhound/chunks.duckdb"
      ]
    }
  }
}
