{
  "mcpServers": {
    "remote-example": {
      "command": "ssh",
      "args": [
        "-i",
        "/ABSOLUTE/PATH/.ssh/id_ed25519",
        "-o",
        "BatchMode=yes",
        "-o",
        "ConnectTimeout=15",
        "USER@vps.example",
        "bash -lc 'cd /path/to/Spectra && exec /path/to/venv/bin/your-mcp-stdio-server'"
      ]
    }
  }
}
