# Test environment configuration
# Loaded by pytest-dotenv via pyproject.toml for local pytest runs.
# Docker-based test runners also mount or reference this file directly.

DATABASE_URL=postgresql+asyncpg://spectra:spectra_test@localhost:5433/spectra_test
DATA_ROOT=/app/data
JWT_SECRET_KEY=test-secret-key-for-testing
SECRET_KEY=test-secondary-secret-key
SERVICE_AUTH_SECRET=test-service-auth-secret
AI_SERVICE_URL=http://ai-svc:5010
TENSORZERO_GATEWAY_URL=http://tensorzero:3000
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=text
REQUEST_TIMEOUT_SECONDS=30
PLUGIN_SAFE_MODE=false
FULLY_AUTOMATED=true
SANDBOX_IMAGE_SCAN_ENABLED=false
PLATFORM_EXPOSED=false

# --- LLM live testing ---
LLM_API_KEY=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
OPENAI_API_KEY=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
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Redis ---
REDIS_PASSWORD=spectra_test_redis
