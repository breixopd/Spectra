# =============================================================================
# Spectra Configuration
# =============================================================================
# Copy to .env and fill in your values.
# Settings can also be changed from the Settings page in the UI.

# --- AI Provider ---
AI_PROVIDER=api

# Z.AI (GLM models) — default
LLM_API_KEY=your-z-ai-api-key
LLM_API_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL=glm-4.7-flash

# Qwen (Alibaba DashScope) — alternative
# LLM_API_KEY=your-dashscope-api-key
# LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3-32b

# --- Security ---
JWT_SECRET_KEY=change-me-in-production
REDIS_PASSWORD=changeme

# --- Notifications (optional) ---
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic

# --- Application ---
DEBUG=true
LOG_LEVEL=INFO
RAG_BACKEND=redis
