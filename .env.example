# =============================================================================
# Spectra Configuration
# =============================================================================
# Copy to .env and fill in the required values.
# AI/LLM settings are configured through the web UI after first launch.

# --- Required ---
# Secret key for JWT authentication tokens — generate a strong random value
JWT_SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL connection string (must match docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://spectra:spectra_dev@db:5432/spectra
POSTGRES_PASSWORD=spectra_dev

# --- Security ---
# SECRET_KEY=  # App encryption key (auto-generated if empty)
# ACCESS_TOKEN_EXPIRE_MINUTES=240  # JWT token lifetime (default 4 hours)
# JWT_ALGORITHM=HS256  # JWT signing algorithm
# PLUGIN_SAFE_MODE=true  # Enforce plugin signature verification
# REQUIRE_APPROVAL=false  # Require human approval for high-risk actions
# FULLY_AUTOMATED=true  # Skip human approval for all actions

# --- General ---
# APP_NAME=Spectra
# DEBUG=false
# LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT=text  # "text" for development, "json" for structured production logs
# REQUEST_TIMEOUT_SECONDS=60  # Cancel requests exceeding this (0 = disabled)
# DATABASE_ECHO=false  # Log all SQL queries
# DATABASE_POOL_SIZE=20
# DATABASE_MAX_OVERFLOW=10
# CONNECT_BACK_HOST=spectra-app  # Hostname tools container uses to reach the app

# --- CORS ---
# CORS_ORIGINS=["http://localhost:5000"]  # Comma-separated or JSON list of allowed origins

# --- Request Limits ---
# MAX_REQUEST_BODY_SIZE=10485760  # Max upload size in bytes (default 10 MB)

# --- AI / LLM ---
# AI_PROVIDER=litellm  # litellm (all models), ollama, mock (testing)
# OLLAMA_HOST=http://ai:11434
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_ENABLED=false  # Whether Ollama is available as secondary provider

# Cloud/API provider
# LLM_API_KEY=sk-...  # API key for LLM provider
# LLM_API_BASE_URL=https://api.openai.com/v1  # OpenAI-compatible endpoint
# LLM_MODEL=gpt-4o-mini  # Default LLM model
# LLM_TIMEOUT=600.0  # LLM request timeout in seconds

# Per-tier model routing (empty = use default model for all tiers)
# LLM_TIER1_MODEL=  # Fast/cheap: scope, tool selection, parsing
# LLM_TIER2_MODEL=  # Balanced: planning, steering, reporting
# LLM_TIER3_MODEL=  # Capable: exploit crafting, PoC generation

# Embedding model (must be supported by LLM_API_BASE_URL provider)
# EMBEDDING_MODEL=text-embedding-3-small

# --- Email / SMTP ---
# SMTP_HOST=  # SMTP server hostname
# SMTP_PORT=587  # SMTP server port
# SMTP_USER=  # SMTP username
# SMTP_PASSWORD=  # SMTP password
# SMTP_FROM=  # Sender email address
# SMTP_USE_TLS=true  # Use TLS for SMTP connection

# --- Sandbox Pool ---
# SANDBOX_IMAGE=spectra-tools
# SANDBOX_NETWORK=spectra-network
# SANDBOX_MAX_CONTAINERS=10
# SANDBOX_MEMORY_LIMIT=2g
# SANDBOX_CPU_SHARES=512
# SANDBOX_RESOURCE_TIERS={"light":{"memory":"512m","cpu_shares":256},"medium":{"memory":"2g","cpu_shares":512},"heavy":{"memory":"4g","cpu_shares":1024},"extreme":{"memory":"8g","cpu_shares":2048}}
# SANDBOX_MAX_LIFETIME=7200  # Max sandbox lifetime in seconds
# SANDBOX_WORKER_POLL_DELAY=0.5
# SANDBOX_NETWORK_ISOLATION=true
# SANDBOX_IDLE_TIMEOUT=600  # Destroy sandbox after this many seconds of no heartbeat
# SANDBOX_HEARTBEAT_INTERVAL=30  # Worker heartbeat interval in seconds
# SANDBOX_PER_USER_LIMIT=3  # Max concurrent sandboxes per user
# SANDBOX_DEFAULT_PRIORITY=5  # Default job priority (1=highest, 10=lowest)
# SANDBOX_OOM_ESCALATION_ENABLED=true  # Auto-escalate tier on OOM (exit 137)
# SANDBOX_WARM_POOL_ENABLED=false  # Pre-warm idle containers for instant assignment
# SANDBOX_WARM_POOL_SIZE=2  # Number of pre-warmed containers
# SANDBOX_AUTO_BUILD_IMAGE=true  # Rebuild image when plugins change
# SANDBOX_IMAGE_SCAN_ENABLED=true  # Scan image for CVEs after build
# SANDBOX_IMAGE_SCAN_BLOCK_CRITICAL=false  # Block deploy if critical CVEs found

# --- External Service Gateways ---
# SANDBOX_ORCHESTRATOR_URL=  # Remote sandbox orchestrator (e.g. http://orchestrator:8084)
# SANDBOX_ORCHESTRATOR_TIMEOUT=30
# SANDBOX_ORCHESTRATOR_API_KEY=

# --- VPN ---
# VPN_CONFIG_DIR=/app/vpn_configs
# VPN_ENABLED=true
# VPN_AUTO_CONNECT=  # Reserved for future use

# --- Notifications ---
# NOTIFICATION_WEBHOOK=  # Webhook URL (e.g. https://ntfy.sh/your-topic)

# --- Platform ---
# PLATFORM_DOMAIN=  # Public domain (e.g. spectra.example.com)
# PLATFORM_BASE_URL=  # Full base URL (e.g. https://spectra.example.com)
# PLATFORM_EXPOSED=false  # Whether platform is accessible from the internet

# --- Object Storage (S3/MinIO) ---
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=spectra
# S3_SECRET_KEY=spectra_minio_dev
# S3_REGION=us-east-1
# S3_BUCKET_MISSIONS=spectra-missions
# S3_BUCKET_SESSIONS=spectra-sessions
# S3_BUCKET_KNOWLEDGE=spectra-knowledge
# S3_BUCKET_BACKUPS=spectra-backups

# --- Networking ---
# CONNECT_BACK_HOST=spectra-app  # Hostname tools container uses to reach app
