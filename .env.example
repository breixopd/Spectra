# =============================================================================
# Spectra Configuration
# =============================================================================
# Copy to .env and fill in your values.
# Settings can also be changed from the Settings page in the UI.

# --- AI Provider ---
# Supported: litellm (cloud/API gateway), ollama, mock
AI_PROVIDER=litellm

# Qwen (Alibaba DashScope) — recommended
LLM_API_KEY=your-dashscope-api-key
LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-32b

# OpenAI — alternative
# LLM_API_KEY=sk-...
# LLM_API_BASE_URL=  # leave empty for OpenAI default
# LLM_MODEL=gpt-4o-mini

# Z.AI (GLM models)
# LLM_API_KEY=your-z-ai-api-key
# LLM_API_BASE_URL=https://api.z.ai/api/coding/paas/v4
# LLM_MODEL=glm-4.7-flash

# Qwen via Ollama (local)
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://ai:11434
# OLLAMA_MODEL=qwen2.5:7b   # or qwen2.5:3b for lighter

# Qwen via LiteLLM + Ollama
# AI_PROVIDER=litellm
# LLM_MODEL=ollama/qwen2.5:7b

# --- Per-Tier Model Routing (optional) ---
# When set, different task types use different models for cost/quality tradeoff.
# When empty, all tiers use the default model (LLM_MODEL / OLLAMA_MODEL).
# LLM_TIER1_MODEL=   # Cheap/fast: scope parsing, tool selection, safety checks
# LLM_TIER2_MODEL=   # Balanced: planning, steering, reporting
# LLM_TIER3_MODEL=   # Capable: exploit crafting, PoC generation, post-exploitation
#
# Examples with Ollama:
#   LLM_TIER1_MODEL=ollama/qwen2.5:3b
#   LLM_TIER2_MODEL=ollama/qwen2.5:7b
#   LLM_TIER3_MODEL=ollama/qwen2.5:14b
#
# Examples with cloud APIs:
#   LLM_TIER1_MODEL=glm-4.7-flash
#   LLM_TIER2_MODEL=glm-4.7-flashx
#   LLM_TIER3_MODEL=glm-4.7

# --- Database ---
# PostgreSQL password (matches POSTGRES_PASSWORD in docker-compose.yml)
# POSTGRES_PASSWORD=spectra_dev

# --- Network ---
# Port for the Spectra web UI (change if 5000 is in use)
# SPECTRA_PORT=5000

# --- Security ---
JWT_SECRET_KEY=change-me-in-production

# --- Notifications (optional) ---
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic

# --- Application ---
DEBUG=true
LOG_LEVEL=INFO
