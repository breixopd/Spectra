# =============================================================================
# Spectra Configuration
# =============================================================================
# Copy to .env and fill in the required values.
# AI/LLM settings are configured through the web UI after first launch.

# --- Required ---
# Secret key for JWT authentication tokens — generate a strong random value
JWT_SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL password (must match docker-compose.yml)
POSTGRES_PASSWORD=spectra_dev

# --- Security ---
# SECRET_KEY=  # App encryption key (auto-generated if empty)
# ACCESS_TOKEN_EXPIRE_MINUTES=240  # JWT token lifetime (default 4 hours)
# CORS_ORIGINS=["http://localhost:5000"]  # Allowed CORS origins

# --- General ---
# DEBUG=false
# LOG_LEVEL=INFO
# FULLY_AUTOMATED=true  # Skip human approval for all actions
# PLUGIN_SAFE_MODE=true  # Enforce plugin signature verification
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic

# --- Sandbox Pool ---
# SANDBOX_IMAGE=spectra-tools
# SANDBOX_NETWORK=spectra-network
# SANDBOX_MAX_CONTAINERS=10
# SANDBOX_MEMORY_LIMIT=2g
# SANDBOX_CPU_SHARES=512
# SANDBOX_MAX_LIFETIME=7200
# SANDBOX_NETWORK_ISOLATION=true
# SANDBOX_PER_USER_LIMIT=3
# SANDBOX_WARM_POOL_ENABLED=false
# SANDBOX_IMAGE_SCAN_ENABLED=true

# --- Object Storage (S3/MinIO) ---
# S3_ENDPOINT_URL=http://minio:9000
# S3_ACCESS_KEY=spectra
# S3_SECRET_KEY=spectra_minio_dev
# S3_REGION=us-east-1

# --- External Service Gateways ---
# SANDBOX_ORCHESTRATOR_URL=  # Remote sandbox orchestrator
# SANDBOX_ORCHESTRATOR_API_KEY=

# --- VPN ---
# VPN_ENABLED=true
# VPN_CONFIG_DIR=/app/vpn_configs

# --- Platform (for multi-server / public deployment) ---
# PLATFORM_DOMAIN=spectra.local
# PLATFORM_BASE_URL=http://localhost:5000
# PLATFORM_EXPOSED=false
