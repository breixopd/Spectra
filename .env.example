# ═══════════════════════════════════════════════════════════════
# Spectra Platform — Example Environment
# ═══════════════════════════════════════════════════════════════
# Safe example values for local compose validation and initial setup.
# Replace any change-me-* values before a real deployment.
# If you want first_run.sh to auto-generate a secret in .env, leave that
# variable blank there instead of keeping the placeholder from this file.
# ═══════════════════════════════════════════════════════════════

# ── Deployment / routing ──────────────────────────────────────
# Leave REGISTRY empty to use local image names.
REGISTRY=
VERSION=dev
PLATFORM_DOMAIN=localhost
TLS_MODE=internal
SPECTRA_PORT=80
SPECTRA_HTTPS_PORT=443
APP_REPLICAS=2
BACKUP_ENABLED=false
CALLBACK_RELAY_HOST=localhost
WORKER_CPU_LIMIT=2.0
WORKER_MEMORY_LIMIT=4G

# ── Core service credentials ──────────────────────────────────
POSTGRES_PASSWORD=change-me-db-password
REDIS_PASSWORD=change-me-redis-pass
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
SERVICE_AUTH_SECRET=change-me-service-auth-secret

# ── Object storage / Garage ───────────────────────────────────
GARAGE_ACCESS_KEY=GK_TEST_ACCESS_KEY
GARAGE_SECRET_KEY=test-garage-secret
GARAGE_RPC_SECRET=change-me-garage-rpc-secret
# Optional in local compose, but define it here so swarm validation has a value.
GARAGE_ADMIN_TOKEN=change-me-garage-admin-token

# ── Optional platform-level LLM providers ─────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
ANTHROPIC_API_KEY=
SESSION_IDLE_TIMEOUT_MINUTES=1440
