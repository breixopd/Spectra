# ═══════════════════════════════════════════════════════════════
# Spectra Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Only infrastructure passwords and your AI provider key are needed.
# Security secrets (JWT, encryption, service auth) are auto-generated.
# All other settings are managed via the Settings page after launch.
# ═══════════════════════════════════════════════════════════════

# ── AI Provider (required) ────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://spectra:${POSTGRES_PASSWORD}@db:5432/spectra

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-pass
RATE_LIMIT_STORAGE=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Object Storage ────────────────────────────────────────────
GARAGE_ACCESS_KEY=GK0000000000000000000000000
GARAGE_SECRET_KEY=change-me-garage-secret
S3_ENDPOINT_URL=http://garage:3900

# ── ClickHouse (TensorZero backend) ──────────────────────────
CLICKHOUSE_PASSWORD=change-me-clickhouse
