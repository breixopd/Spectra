# =============================================================================
# Spectra Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All AI/LLM settings can also be configured from the Settings page in the UI.

# --- AI / LLM Provider ---
# Options: "ollama" (local), "api" (cloud), "mock" (testing)
AI_PROVIDER=api

# Cloud API settings (when AI_PROVIDER=api)
LLM_API_KEY=your-api-key-here
LLM_API_BASE_URL=https://api.z.ai/api/coding/paas/v4
LLM_MODEL=glm-4.7-flash

# Ollama settings (when AI_PROVIDER=ollama)
# OLLAMA_HOST=http://ai:11434
# OLLAMA_MODEL=qwen3:8b

# --- Security ---
JWT_SECRET_KEY=change-me-in-production
REDIS_PASSWORD=changeme

# --- Notifications (optional) ---
# Set to receive mission event notifications
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic

# --- Application ---
DEBUG=true
LOG_LEVEL=INFO
# PLUGIN_SAFE_MODE=true
# FULLY_AUTOMATED=true
