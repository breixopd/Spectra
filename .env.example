# =============================================================================
# Spectra — Environment Configuration
# =============================================================================
# This file contains ONLY what's needed to boot the application.
# All other settings (AI routing, sandbox config, email, billing, etc.)
# are configured through the Setup Wizard on first launch or the Admin Panel.
#
# Copy to .env and fill in the required values.

# --- Secrets ---
# Both are auto-generated if empty. Set for stable sessions across restarts.
# JWT_SECRET_KEY=
# SECRET_KEY=

# --- Required: Database ---
DATABASE_URL=postgresql+asyncpg://spectra:spectra_dev@db:5432/spectra
POSTGRES_PASSWORD=spectra_dev

# --- Required: Object Storage ---
MINIO_ROOT_USER=spectra
MINIO_ROOT_PASSWORD=spectra_minio_dev

# --- AI Gateway (TensorZero) ---
# TensorZero handles all AI provider routing. Set the provider API key here.
# Using OpenRouter (recommended — free tier available):
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
#
# Using OpenAI directly:
# OPENAI_API_KEY=sk-your-openai-key-here
# (no OPENAI_BASE_URL needed)
#
# Using Anthropic:
# ANTHROPIC_API_KEY=sk-ant-your-key-here
#
# Using local Ollama:
# OPENAI_API_KEY=not-needed
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1

# --- Optional: Debug ---
# DEBUG=false
# LOG_LEVEL=INFO
# LOG_FORMAT=text
