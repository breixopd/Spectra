# =============================================================================
# Spectra — environment configuration
# =============================================================================
# Copy to .env before running docker compose.
# This file is intentionally env-first: no setup wizard is required for core deploys.

# --- Core secrets (required) ---
JWT_SECRET_KEY=change-me-with-a-long-random-value
SECRET_KEY=change-me-with-a-different-long-random-value
SERVICE_AUTH_SECRET=change-me-shared-between-app-ai-scheduler-worker

# --- Public platform identity ---
SPECTRA_DOMAIN=localhost
PLATFORM_DOMAIN=localhost
PLATFORM_BASE_URL=http://localhost
PLATFORM_EXPOSED=false

# --- Database (required) ---
POSTGRES_PASSWORD=change-me-db-password
DB_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://spectra:${POSTGRES_PASSWORD}@db:5432/spectra

# --- Object storage / Garage (required) ---
GARAGE_ACCESS_KEY=spectra
GARAGE_SECRET_KEY=change-me-garage-password
S3_REGION=us-east-1
S3_BUCKET_MISSIONS=spectra-missions
S3_BUCKET_SESSIONS=spectra-sessions
S3_BUCKET_KNOWLEDGE=spectra-knowledge
S3_BUCKET_BACKUPS=spectra-backups

# --- Shared rate limiting ---
RATE_LIMIT_STORAGE=redis://redis:6379/0

# --- TensorZero / provider routing ---
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
TENSORZERO_GATEWAY_URL=http://tensorzero:3000

# --- Logging / runtime ---
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_TIMEOUT_SECONDS=60
AUDIT_LOG_RETENTION_DAYS=365

# --- Email (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=mailer@example.com
# SMTP_PASSWORD=change-me
# SMTP_FROM=Spectra <no-reply@example.com>
# EMAIL_VERIFICATION_ENABLED=true

# --- Billing / webhooks / backups (optional) ---
# BACKUP_ENABLED=true
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
