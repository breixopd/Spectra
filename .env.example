# ═══════════════════════════════════════════════════════════════
# Spectra Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# This file contains ONLY infrastructure secrets and external API keys.
# All other settings are managed via the Settings page after first launch.
#
# Quick start:
#   ./scripts/first_run.sh
#   (Secrets are auto-generated — you only need to add your AI API key)
# ═══════════════════════════════════════════════════════════════

# ── AI Provider (required) ────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ── Secrets (auto-generated by first_run.sh) ──────────────────
JWT_SECRET_KEY=change-me-with-a-long-random-value
SECRET_KEY=change-me-with-a-different-long-random-value
SERVICE_AUTH_SECRET=change-me-shared-between-app-ai-scheduler-worker

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://spectra:${POSTGRES_PASSWORD}@db:5432/spectra

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-pass
RATE_LIMIT_STORAGE=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Object Storage (auto-configured by first_run.sh) ─────────
GARAGE_ACCESS_KEY=GK0000000000000000000000000
GARAGE_SECRET_KEY=change-me-garage-secret
S3_ENDPOINT_URL=http://garage:3900
S3_REGION=us-east-1

# ── ClickHouse (TensorZero backend) ──────────────────────────
CLICKHOUSE_PASSWORD=change-me-clickhouse
