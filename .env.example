# =============================================================================
# Spectra — Environment Configuration
# =============================================================================
# This file contains ONLY what's needed to boot the application.
# All other settings (AI routing, sandbox config, email, billing, etc.)
# are configured through the Setup Wizard on first launch or the Admin Panel.
#
# Copy to .env and fill in the required values.

# --- Required: Secrets ---
JWT_SECRET_KEY=change-me-to-a-random-secret
# SECRET_KEY=  # App encryption key (auto-generated if empty)

# --- Required: Database ---
DATABASE_URL=postgresql+asyncpg://spectra:spectra_dev@db:5432/spectra
POSTGRES_PASSWORD=spectra_dev

# --- Required: Object Storage ---
MINIO_ROOT_USER=spectra
MINIO_ROOT_PASSWORD=spectra_minio_dev

# --- Optional: AI Provider ---
# Set these for initial LLM access before running the Setup Wizard.
# After setup, the admin panel manages all AI routing and model config.
# AI_PROVIDER=openrouter
# LLM_API_KEY=sk-or-v1-...
# LLM_API_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openrouter/arcee-ai/trinity-large-preview:free

# If using Ollama locally:
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://ai:11434
# OLLAMA_MODEL=qwen2.5:3b

# --- Optional: Debug ---
# DEBUG=false
# LOG_LEVEL=INFO
# LOG_FORMAT=text
