# =============================================================================
# Spectra Security Assessment Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.
# Most settings can be configured via the /setup page on first run.

# --- Application ---
DEBUG=false
LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
# Default works with docker-compose. Change for external database.
DATABASE_URL=postgresql+asyncpg://spectra:spectra_dev@db:5432/spectra

# --- Redis ---
# Default works with docker-compose. Change for external Redis.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# --- Security (MUST change in Production!) ---
JWT_SECRET_KEY=change-me-in-production

# =============================================================================
# OPTIONAL: Pre-configure LLM (otherwise set via /setup page)
# =============================================================================
# Provider: "ollama" (local) or "api" (cloud/remote)
# AI_PROVIDER=ollama

# Ollama (Local LLM) - requires Ollama service running
# OLLAMA_HOST=http://ai:11434
# OLLAMA_MODEL=qwen2.5:3b

# Cloud/API Provider (OpenAI, OpenRouter, Anthropic, etc.)
# Set AI_PROVIDER=api to use these settings
# LLM_API_KEY=your-api-key
# LLM_API_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
