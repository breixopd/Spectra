# =============================================================================
# Spectra — environment configuration
# =============================================================================
# Copy to .env before running docker compose.
# This file is intentionally env-first: no setup wizard is required for core deploys.
#
# Settings marked [Admin UI] can be managed via Admin UI after initial setup.
# Env vars serve as initial defaults; the database (via Admin UI) is the
# source of truth after first boot.

# --- Core secrets (required) ---
JWT_SECRET_KEY=change-me-with-a-long-random-value
SECRET_KEY=change-me-with-a-different-long-random-value
SERVICE_AUTH_SECRET=change-me-shared-between-app-ai-scheduler-worker

# --- Public platform identity ---
# [Admin UI] PLATFORM_DOMAIN, PLATFORM_BASE_URL, PLATFORM_EXPOSED
SPECTRA_DOMAIN=localhost
PLATFORM_DOMAIN=localhost
PLATFORM_BASE_URL=http://localhost
PLATFORM_EXPOSED=false

# --- Database (required) ---
POSTGRES_PASSWORD=change-me-db-password
DB_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+asyncpg://spectra:${POSTGRES_PASSWORD}@db:5432/spectra

# --- Object storage / Garage (required) ---
GARAGE_ACCESS_KEY=spectra
GARAGE_SECRET_KEY=change-me-garage-password
S3_REGION=us-east-1
S3_BUCKET_MISSIONS=spectra-missions
S3_BUCKET_SESSIONS=spectra-sessions
S3_BUCKET_KNOWLEDGE=spectra-knowledge
S3_BUCKET_BACKUPS=spectra-backups

# --- Shared rate limiting ---
REDIS_PASSWORD=change-me-redis-pass
RATE_LIMIT_STORAGE=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- TensorZero / provider routing ---
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
TENSORZERO_GATEWAY_URL=http://tensorzero:3000

# --- ClickHouse (TensorZero backend) ---
# Set a strong password to protect inference data at rest
CLICKHOUSE_PASSWORD=change_me_clickhouse

# --- Logging / runtime ---
# [Admin UI] LOG_LEVEL
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json
REQUEST_TIMEOUT_SECONDS=60
AUDIT_LOG_RETENTION_DAYS=365

# --- Email (optional) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=mailer@example.com
# SMTP_PASSWORD=change-me
# SMTP_FROM=Spectra <no-reply@example.com>
# EMAIL_VERIFICATION_ENABLED=true

# --- Billing / webhooks / backups (optional) ---
# [Admin UI] BACKUP_ENABLED, NOTIFICATION_WEBHOOK
# BACKUP_ENABLED=true
# NOTIFICATION_WEBHOOK=https://ntfy.sh/your-topic
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=

# --- Auto-Scaling (optional) ---
# [Admin UI] All AUTOSCALE_* settings can be managed via Admin UI → Scaling tab.
# Env vars below are initial defaults only; DB is the source of truth after first boot.
# AUTOSCALE_ENABLED=false
# AUTOSCALE_WORKER_MIN=1
# AUTOSCALE_WORKER_MAX=10
# AUTOSCALE_API_MIN=2
# AUTOSCALE_API_MAX=8
# AUTOSCALE_AI_MAX=4
# AUTOSCALE_QUEUE_THRESHOLD=5
# AUTOSCALE_COOLDOWN_SECS=300
# AUTOSCALE_IDLE_SECS=600
# AUTOSCALE_CPU_UP_THRESHOLD=75
# AUTOSCALE_CPU_DOWN_THRESHOLD=25

# --- Infrastructure Monitoring (optional) ---
# [Admin UI] All INFRA_MONITOR_* settings can be managed via Admin UI.
# INFRA_MONITOR_ENABLED=true
# INFRA_MONITOR_PG_THRESHOLD=80
# INFRA_MONITOR_REDIS_THRESHOLD=85
# INFRA_MONITOR_STORAGE_THRESHOLD=90

# --- Swarm Service Names (auto-detected by default) ---
# SWARM_WORKER_SERVICE=spectra_worker
# SWARM_API_SERVICE=spectra_app
# SWARM_AI_SERVICE=spectra_ai-svc
# SWARM_SCHEDULER_SERVICE=spectra_scheduler
