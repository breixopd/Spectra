# Live test environment — copy to .env.live and fill in values
# Used by ./tests/run_live_tests.sh for integration testing with real LLM

AI_PROVIDER=openrouter

# --- OpenRouter (recommended) ---
LLM_API_KEY=sk-or-v1-your-key-here
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openrouter/arcee-ai/trinity-large-preview:free

# --- OpenAI (alternative) ---
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini

# --- Tier routing (optional) ---
# LLM_TIER1_MODEL=openrouter/meta-llama/llama-4-scout:free
# LLM_TIER2_MODEL=openrouter/arcee-ai/trinity-large-preview:free
# LLM_TIER3_MODEL=openrouter/anthropic/claude-sonnet-4

# EMBEDDING_MODEL=local/BAAI/bge-small-en-v1.5
