# Live test environment — copy to .env.live and fill in values
# Used by ./tests/run_live_tests.sh for integration testing with real LLM

AI_PROVIDER=litellm

# --- DashScope (Qwen) ---
LLM_API_KEY=your-dashscope-key
LLM_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-plus

# --- OpenAI (alternative) ---
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini

# --- Tier routing (optional) ---
# LLM_TIER1_MODEL=qwen3.5-flash
# LLM_TIER2_MODEL=qwen3.5-plus
# LLM_TIER3_MODEL=qwen3.5-397b-a17b

# EMBEDDING_MODEL=text-embedding-v3
