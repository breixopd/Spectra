# Spectra reverse proxy used by the Docker test stack.
# Keeps the production routing shape, but lowers selected edge thresholds
# so the burst harness can verify proxy-layer 429 behavior quickly.

import Caddyfile.snippets

{
auto_https off
admin off
}

:80 {
import security_headers

@websocket {
Connection *Upgrade*
Upgrade websocket
}

route {
uest_body {
50MB

dle /static/* {
Cache-Control "public, max-age=3600"
 app:5000 app-replica:5000

dle @websocket {
 app:5000 app-replica:5000 {
 round_robin

proxy_defaults

{
e setup_status_edge {
{
/api/auth/setup/status /api/v1/auth/setup/status
 {remote_host}
ts 10000
dow 1m

e public_auth {
{
public_auth ^(?:/(?:login|setup|forgot-password|reset-password)|/api(?:/v1)?/auth/(?:token|refresh|setup|forgot-password|reset-password|mfa/(?:verify|cancel)))$
 {remote_host}
ts 10000
dow 1m

e public_register {
{
public_register ^(?:/register|/api/public/register)$
 {remote_host}
ts 10000
dow 1m

 app:5000 app-replica:5000 {
 round_robin
/api/health
terval 10s
5s

proxy_defaults

import error_pages

log {
stdout
console
INFO
}
}
