# Spectra reverse proxy used by the Docker test stack.
# Keeps the production routing shape, but lowers selected edge thresholds
# so the burst harness can verify proxy-layer 429 behavior quickly.

{
	auto_https off
	admin off
}

:80 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}

	route {
		handle @websocket {
			reverse_proxy app:5000 app-replica:5000 {
				lb_policy round_robin

				transport http {
					read_timeout 300s
					write_timeout 300s
					dial_timeout 10s
				}

				header_up X-Real-IP {remote_host}
				header_up X-Forwarded-For {remote_host}
				header_up X-Forwarded-Proto {scheme}
			}
		}

		rate_limit {
			zone setup_status_edge {
				match {
					path /api/auth/setup/status /api/v1/auth/setup/status
				}
				key {remote_host}
				events 10000
				window 1m
			}

			zone public_auth {
				match {
					path_regexp public_auth ^(?:/(?:login|setup|forgot-password|reset-password)|/api(?:/v1)?/auth/(?:token|refresh|setup|forgot-password|reset-password|mfa/(?:verify|cancel)))$
				}
				key {remote_host}
				events 10000
				window 1m
			}

			zone public_register {
				match {
					path_regexp public_register ^(?:/register|/api/public/register)$
				}
				key {remote_host}
				events 10000
				window 1m
			}
		}

		reverse_proxy app:5000 app-replica:5000 {
			lb_policy round_robin
			health_uri /api/health
			health_interval 10s
			health_timeout 5s

			transport http {
				read_timeout 300s
				write_timeout 300s
				dial_timeout 10s
			}

			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle_errors {
		@api path /api/*
		handle @api {
			header Content-Type application/json
			respond "{\"error\":\"service_unavailable\",\"message\":\"Server is starting up or temporarily unavailable\"}" 503
		}
		handle {
			header Content-Type "text/html; charset=utf-8"
			respond "<!DOCTYPE html><html><head><title>Service Unavailable</title><style>body{font-family:system-ui;display:flex;justify-content:center;align-items:center;min-height:100vh;margin:0;background:#0f172a;color:#e2e8f0}.c{text-align:center}h1{font-size:3rem;margin-bottom:.5rem}p{color:#94a3b8}</style></head><body><div class='c'><h1>503</h1><p>Spectra is starting up or temporarily unavailable.</p><p>Please try again in a few moments.</p></div></body></html>" 503
		}
	}

	log {
		output stdout
		format console
		level INFO
	}
}