FROM mcr.microsoft.com/playwright/python:v1.58.0-jammy

WORKDIR /app

COPY . .

# Install the app and test dependencies needed for browser tests.
RUN grep -vE '^(pytest|pytest-asyncio|pytest-cov|pytest-dotenv|pytest-timeout)==' requirements/base.txt > /tmp/base-no-pytest.txt \
    && grep -v '^-r base.txt$' requirements/dev.txt > /tmp/dev-no-base.txt \
    && pip install --no-cache-dir -r /tmp/base-no-pytest.txt -r /tmp/dev-no-base.txt pytest-playwright playwright==1.58.0
