# Spectra reverse proxy for local / single-host deployments.
# The application sets CSP and the rest of the browser-security policy.

{
	auto_https off
	admin off
}

:80 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	handle @websocket {
		reverse_proxy spectra-app:5000
	}

	reverse_proxy spectra-app:5000 {
		health_uri /api/health
		health_interval 10s
		health_timeout 5s

		transport http {
			read_timeout 300s
			write_timeout 300s
			dial_timeout 10s
		}

		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}

	log {
		output stdout
		format console
		level INFO
	}
}
