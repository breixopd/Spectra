# Spectra reverse proxy for local / single-host deployments.
# The application sets CSP and the rest of the browser-security policy.

{
	auto_https off
	admin off
}

:80 {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	route {
		handle @websocket {
			reverse_proxy spectra-app:5000
		}

		# Thin IP-based edge guard for public auth traffic only.
		# Redis-backed application limits remain the primary policy layer.
		rate_limit {
			zone public_auth {
				match {
					path_regexp public_auth ^(?:/(?:login|setup|forgot-password|reset-password)|/api(?:/v1)?/auth/(?:token|refresh|setup|forgot-password|reset-password|mfa/(?:verify|cancel)))$
				}
				key {remote_host}
				events 30
				window 1m
			}

			zone public_register {
				match {
					path_regexp public_register ^(?:/register|/api/public/register)$
				}
				key {remote_host}
				events 30
				window 1m
			}
		}

		reverse_proxy spectra-app:5000 {
			health_uri /api/health
			health_interval 10s
			health_timeout 5s

			transport http {
				read_timeout 300s
				write_timeout 300s
				dial_timeout 10s
			}

			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle_errors {
		@api path /api/*
		respond @api "{\"error\":\"service_unavailable\",\"message\":\"Server is starting up or temporarily unavailable\"}" 503 {
			header Content-Type application/json
		}
		respond "<!DOCTYPE html><html><head><title>Service Unavailable</title><style>body{font-family:system-ui;display:flex;justify-content:center;align-items:center;min-height:100vh;margin:0;background:#0f172a;color:#e2e8f0}.c{text-align:center}h1{font-size:3rem;margin-bottom:.5rem}p{color:#94a3b8}</style></head><body><div class='c'><h1>503</h1><p>Spectra is starting up or temporarily unavailable.</p><p>Please try again in a few moments.</p></div></body></html>" 503 {
			header Content-Type text/html
		}
	}

	log {
		output stdout
		format console
		level INFO
	}
}
