# Spectra reverse proxy for local / single-host deployments.
import Caddyfile.snippets

{
	auto_https off
	admin off
}

:80 {
	import security_headers

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}

	route {
		request_body {
			max_size 50MB
		}

		handle /static/* {
			header Cache-Control "public, max-age=3600"
			reverse_proxy spectra-app:5000
		}

		handle @websocket {
			reverse_proxy spectra-app:5000
		}

		# IP-based edge guard for public auth traffic.
		# Redis-backed application limits remain the primary policy layer.
		import rate_limit_public 30

		reverse_proxy spectra-app:5000 {
			health_uri /api/health
			health_interval 10s
			health_timeout 5s

			import proxy_defaults
		}
	}

	import error_pages

	log {
		output stdout
		format console
		level INFO
	}
}
