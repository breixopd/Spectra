# Spectra — Caddy reverse proxy configuration
#
# For production, replace :443 with your domain:
#   spectra.example.com {
#
# Caddy auto-provisions TLS via Let's Encrypt when a real domain is used.

import Caddyfile.snippets

:80 {
import security_headers

@websocket {
Connection *Upgrade*
Upgrade websocket
}

route {
uest_body {
50MB

dle /static/* {
Cache-Control "public, max-age=3600"
 spectra-app:5000

dle @websocket {
 spectra-app:5000

Thin IP-based edge guard for public auth traffic only.
Redis-backed application limits remain the primary policy layer.
rate_limit_public 30

 spectra-app:5000 {
/api/health
terval 10s
5s

proxy_defaults

import error_pages

log {
file /data/access.log {
100mb
5
}
