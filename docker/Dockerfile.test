# Lightweight test runner — not for production use.
# Keeps test dependencies out of the app image.
ARG PYTHON_BASE_IMAGE=python:3.11.13-slim-bookworm

FROM ${PYTHON_BASE_IMAGE} AS test-runner

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_ROOT_USER_ACTION=ignore

WORKDIR /app

# System deps for asyncpg, psycopg2, etc.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev git \
    && rm -rf /var/lib/apt/lists/*

# Install all dependencies including test deps.
# base.txt pins pytest 9 + pytest-asyncio 0.24 which have a resolver
# conflict (pytest-asyncio 0.24 declares pytest<9). They're compatible at
# runtime, so install deps first then force the asyncio pin. Add API runtime
# extras imported by unit tests without pulling PDF/native build-only deps.
COPY requirements/ requirements/
RUN grep -v -E 'pytest-asyncio|pytest==' requirements/base.txt > /tmp/base-filtered.txt \
    && pip install --no-cache-dir -r /tmp/base-filtered.txt numpy pytest==8.3.5 \
    && pip install --no-cache-dir aiofiles==25.1.0 aiohttp==3.13.5 aioboto3==15.5.0 docker==7.0.0 asyncssh==2.22.0 aiosmtplib==3.0.0 psutil==7.2.2 aiosqlite==0.21.0 \
    && pip install --no-cache-dir pytest-asyncio==0.25.3 \
    && pip install --no-cache-dir pytest-cov pytest-timeout httpx redis websockets ruff "bandit[toml]"

# Copy source
COPY app/ app/
COPY tests/ tests/
COPY scripts/ scripts/
COPY plugins/ plugins/
COPY config/ config/
COPY alembic/ alembic/
COPY pyproject.toml .

# Default: run unit tests
CMD ["python3", "-m", "pytest", "tests/unit/", "-q", "--no-cov"]
