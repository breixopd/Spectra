import Caddyfile.snippets

{
	auto_https off
	admin off
}

# Bind all Host headers on port 80 (127.0.0.1:15080, localhost, etc.) for local dev.
:80 {
	import security_headers

	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}

	route {
		request_body {
			max_size 50MB
		}

		handle /static/* {
			header Cache-Control "public, max-age=3600"
			reverse_proxy {$APP_UPSTREAM:app:5000}
		}

		handle /assets/* {
			header Cache-Control "public, max-age=604800, immutable"
			reverse_proxy {$APP_UPSTREAM:app:5000}
		}

		handle @websocket {
			reverse_proxy {$APP_UPSTREAM:app:5000}
		}

		import rate_limit_public 30

		reverse_proxy {$APP_UPSTREAM:app:5000} {
			# Use process liveness for proxy membership.  /api/health is an
			# intentionally dependency-aware platform diagnostic and can be
			# degraded while this API instance remains safe to serve.
			health_uri /api/healthz
			health_interval 10s
			health_timeout 5s

			import proxy_defaults
		}
	}

	import error_pages

	log {
		output file /data/access.log {
			roll_size 100mb
			roll_keep 5
		}
		format console
		level INFO
	}
}
