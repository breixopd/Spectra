# Test environment — copy to .env.test and adjust locally.
#   cp .env.test.example .env.test
# .env.test is gitignored; never commit API keys. CI bootstraps from this file when needed.
# Docker Compose (`docker/compose.yaml` with `--profile app`/`--profile test`) overrides several values.

# --- Core (pytest / compose env_file) ---
# Host-side pytest uses published DB port; compose app/worker services use db:5432 via
# docker/compose.yaml (`COMPOSE_DATABASE_URL` overrides when pointing compose at external Postgres).
DATABASE_URL=postgresql+asyncpg://spectra:spectra_test@localhost:5433/spectra_test
JWT_SECRET_KEY=test-secret-key-for-testing-32-bytes-minimum
SECRET_KEY=test-secondary-secret-key-32-bytes-minimum
SERVICE_AUTH_SECRET=test-service-auth-secret-32-bytes-minimum
AI_SERVICE_URL=http://ai-svc:5010
TENSORZERO_GATEWAY_URL=http://tensorzero:3000
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=text
REQUEST_TIMEOUT_SECONDS=30
PLUGIN_SAFE_MODE=false
PLATFORM_EXPOSED=false

# --- LLM (live / integration) — set for OpenRouter or compatible API; leave empty to skip live LLM paths ---
# Live harnesses use LLM_API_KEY; if unset, OPENAI_API_KEY is used (see scripts/live_smoke.py, tests/run_live_tests.sh).
LLM_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings: empty EMBEDDING_API_KEY uses local fastembed (see EMBEDDING_MODEL) ---
EMBEDDING_MODEL=local/BAAI/bge-small-en-v1.5
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=

# --- Redis (host port may differ; compose uses service hostnames) ---
REDIS_PASSWORD=spectra_test_redis
RATE_LIMIT_STORAGE=redis://:spectra_test_redis@redis:6379/0

# --- Rate limits (raise for local UI/automation; prod uses defaults in code) ---
RATE_LIMIT_LOGIN=500/minute

MCP_API_KEY=test-mcp-key-for-dev
